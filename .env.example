# Variables de entorno — Aseguradora ProSalud API

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development

# ── MySQL (db_aseguradora) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3311
DB_USER=aseguradora_app
DB_PASSWORD=app_secret_aseguradora
DB_NAME=db_aseguradora
MYSQL_ROOT_PASSWORD=root_secret_aseguradora

# ── RabbitMQ (broker propio de Seguros) ──────────────────────────────────────
RABBITMQ_URL=amqp://aseguradora_rabbit_user:rabbit_secret@localhost:5673
RABBITMQ_USER=aseguradora_rabbit_user
RABBITMQ_PASSWORD=rabbit_secret_aseguradora

# ── Seguridad API ─────────────────────────────────────────────────────────────
# Clave compartida con MediCitas para validar header X-Api-Key
ASEGURADORA_API_KEY=prosalud_secret_key_2026

# ── Backpressure ──────────────────────────────────────────────────────────────
MAX_SOLICITUDES_CONCURRENTES=50
